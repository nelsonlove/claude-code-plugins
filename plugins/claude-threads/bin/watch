#!/usr/bin/env bash
# claude-threads watcher — emits one event per peer thread message that
# matches your subscriber tags.
#
# Filters (in order, cheap → expensive):
# 1. .md files only; skip dotfiles, .tmp, and the index file (filename matches
#    pattern "<JD-ID> Inter-session threads.md")
# 2. Message-state dedupe: tuple "<count>:<last_author>:<last_at>" only changes
#    on real message activity. NOT the frontmatter `modified:` field — that
#    gets bumped by Obsidian Linter on every pass without any message change.
# 3. Subscriber-tag match (if MY_SESSION_ID is set): scope filter via
#    lib.match (fnmatch + path: prefix). Skip if thread's scope doesn't
#    overlap with this session's tags + implicit handle.
# 4. Skip self-author writes — handle resolved fresh per event from the
#    registry (so /rename mid-watch takes effect; v0.2.1's MY_HANDLE env var
#    captured at arm-time was stale after rename).
#
# Modes:
# - fswatch present (default): event-driven, near-zero idle cost
# - fswatch absent + WATCH_INTERVAL=<seconds>: polling fallback at that rate
# - fswatch absent + no WATCH_INTERVAL: error with usage
#
# Env vars (set by /claude-threads:watch slash command, or by hand):
#   MY_SESSION_ID     — this session's UUID (preferred; enables fresh handle
#                       resolution + scope filter)
#   MY_HANDLE         — fallback only if MY_SESSION_ID absent (legacy v0.2.1
#                       arg shape; doesn't refresh after /rename)
#   WATCH_INTERVAL    — polling-fallback interval in seconds (optional)
#   WATCH_THREADS_DIR — override threads_dir (defaults to claude-threads config)

set -u

PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Resolve threads_dir (env override > config default)
if [ -n "${WATCH_THREADS_DIR:-}" ]; then
  THREADS_DIR="$WATCH_THREADS_DIR"
else
  THREADS_DIR=$(python3 -c "
import sys, os
sys.path.insert(0, '$PLUGIN_DIR')
from lib.config import load_config
cfg = load_config(home=os.path.expanduser('~'), project_root=os.getcwd())
print(cfg['threads_dir'])
")
fi

if [ ! -d "$THREADS_DIR" ]; then
  echo "claude-threads-watch: threads_dir does not exist: $THREADS_DIR" >&2
  exit 1
fi

MY_HANDLE="${MY_HANDLE:-}"
MY_SESSION_ID="${MY_SESSION_ID:-}"
INTERVAL="${WATCH_INTERVAL:-}"

# Per-thread state for message-state dedupe. Key: filename. Value: composite
# tuple "<count>:<last_author>:<last_at>" — only changes on real message
# activity (append, edit-of-last). NOT the frontmatter `modified:` field —
# Obsidian Linter bumps that on every pass without changing messages, which
# in v0.2.1 produced notification storms when the Linter ran (the docstring
# claimed the right semantics; the code didn't match. Fixed here for v0.2.2).
declare -A LAST_STATE

# extract_message_state FILE → echoes "<count>:<last_author>:<last_at>" or empty
# Matches the same strict pattern as lib/poll._parse_headers — requires an
# ISO timestamp anchor in the line, blocking body subheadings like
# `## Trust posture` from being counted as message headers.
#
# v0.2.3 header shape: `## <subject> · <ISO-ts> · <author>` (3 segments,
# author is the LAST · segment). v0.2.0–v0.2.2 legacy: `## <author> · <ts>`
# or `## <author> · <ts> · <model>`. Disambiguate by checking the last
# token: if it matches a known model prefix (unknown/external/claude-/gpt-/
# llama-/mistral-/gemini-), treat as legacy and use field 2 as author;
# else treat as new and use the LAST · segment as author. Timestamp comes
# right after `## .* · ` and matches the ISO pattern.
extract_message_state() {
  awk -F' · ' '
    /^## .+ · [0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]T[0-9][0-9]:[0-9][0-9]:[0-9][0-9]/ {
      count++
      # NF = number of · segments
      first = $1; sub(/^## /, "", first)
      last = $NF
      sub(/[[:space:]]+$/, "", last)
      if (NF >= 3 && last ~ /^(unknown|external|claude-|gpt-|llama-|mistral-|gemini-|anthropic-|openai-)/) {
        # Legacy 3-segment: author=first, model=last
        author = first
      } else if (NF >= 3) {
        # New format: subject=first, author=last
        author = last
      } else {
        # Legacy 2-segment: ## author · ts
        author = first
      }
      # Timestamp is always the segment right after subject/author and before any trailing ·
      at = (NF >= 3) ? $2 : $2
      sub(/[[:space:]]+$/, "", at)
    }
    END {
      if (count > 0) printf "%d:%s:%s", count, author, at
    }
  ' "$1"
}

process_file() {
  local file="$1"
  [ -f "$file" ] || return
  local bn
  bn=$(basename "$file")
  case "$bn" in
    .*|*.tmp) return ;;
  esac
  [[ "$bn" == *.md ]] || return
  # Skip JD index notes (filename pattern "<id> Inter-session threads.md")
  case "$bn" in
    *" Inter-session threads.md") return ;;
  esac
  # Must be a thread file (has thread-id in frontmatter)
  grep -q "^thread-id:" "$file" 2>/dev/null || return

  # Dedupe by message-state tuple — quiet through Linter passes and iCloud
  # sync touches; only fires on real append/edit-of-last activity.
  local cur_state
  cur_state=$(extract_message_state "$file")
  [ -z "$cur_state" ] && return
  if [[ "${LAST_STATE[$bn]:-}" == "$cur_state" ]]; then
    return
  fi
  LAST_STATE[$bn]="$cur_state"

  local last_author current_handle scope_json matches
  last_author=$(echo "$cur_state" | cut -d: -f2)

  # If MY_SESSION_ID is set, use the Python filter helper to:
  #   (a) resolve our CURRENT handle from the registry (catches /rename
  #       mid-watch — v0.2.1's MY_HANDLE env was captured at arm-time)
  #   (b) check whether the thread's scope matches our subscriber tags
  #       (skips firehose: was missing in v0.2.1 entirely)
  if [ -n "$MY_SESSION_ID" ]; then
    scope_json=$(awk '
      /^thread-scope:/ {
        sub(/^thread-scope:[[:space:]]*/, "")
        print
        exit
      }
    ' "$file")
    local filter_out
    filter_out=$(python3 "$PLUGIN_DIR/lib/_watch_filter.py" \
      "$MY_SESSION_ID" "$scope_json" "$HOME" 2>/dev/null)
    current_handle=$(echo "$filter_out" | cut -f1)
    matches=$(echo "$filter_out" | cut -f2)
    [ "$matches" != "1" ] && return
    if [ -n "$current_handle" ] && [[ "$last_author" == "$current_handle" ]]; then
      return
    fi
  else
    # Legacy v0.2.1 path: MY_HANDLE env (no scope filter, no fresh resolution)
    if [ -n "$MY_HANDLE" ] && [[ "$last_author" == "$MY_HANDLE" ]]; then
      return
    fi
  fi

  local tid st last_msg
  tid=$(grep -m1 "^thread-id:" "$file" 2>/dev/null | awk '{print $2}')
  st=$(grep -m1 "^thread-status:" "$file" 2>/dev/null | awk '{print $2}')
  last_msg=$(awk 'BEGIN{RS="\n## "} END{print}' "$file" \
    | sed -n '3,/^—/p' | sed '/^—/d' | tr '\n' ' ' | cut -c1-180)
  echo "[$tid · $st · $last_author] $bn :: $last_msg"
}

# fswatch (event-driven) is the preferred mode
if command -v fswatch >/dev/null; then
  while IFS= read -r -d "" file; do
    process_file "$file"
  done < <(fswatch -0 --latency 0.5 "$THREADS_DIR")
  exit $?
fi

# No fswatch — require explicit interval to enable polling fallback
if [ -z "$INTERVAL" ]; then
  cat >&2 <<EOF
claude-threads-watch: fswatch not found and no polling interval set.

Either install fswatch for event-driven mode (recommended):
  brew install fswatch

Or set WATCH_INTERVAL=<seconds> to enable polling fallback:
  WATCH_INTERVAL=600 $0
EOF
  exit 1
fi

echo "claude-threads-watch: fswatch unavailable; polling every ${INTERVAL}s" >&2
while true; do
  for f in "$THREADS_DIR"/*.md; do
    process_file "$f"
  done
  sleep "$INTERVAL"
done
